float L2Dot(float a[9], float b[9])
{
	float sum = 0;
	for (int i = 0; i < 9; i++)
	{
		sum += a[i] * b[i];
	}
	return sum;
}

float3 SHDot(in FCellFloat first, in FCellFloat second)
{
		
	return float3(L2Dot(first.sh_r, second.sh_r), L2Dot(first.sh_g, second.sh_g), L2Dot(first.sh_b, second.sh_b));
}

float3 SHDotFloatL2(in FCellFloat first, in float secondSH[9])
{
	return float3(L2Dot(first.sh_r, secondSH), L2Dot(first.sh_g, secondSH), L2Dot(first.sh_b, secondSH));
}

void AddContributionFromNeighbor(uint3 id, inout FCellFloat gatheredSHCoeffs, in int3 pos, in int3 offset, in int offsetIndex)
{
	int3 neighborPos = id.xyz + offset;
	
	// if neighbor falls out of grid, skip
	if (neighborPos.x >= _GridWidth || neighborPos.y >= _GridHeight || neighborPos.z >= _GridDepth || neighborPos.x < 1 || neighborPos.y < 1 || neighborPos.z < 1)
	{
		return;
	}
	
	int neighborGridPositionIndex = neighborPos.x + neighborPos.y * (_GridWidth) + neighborPos.z * (_GridWidth * _GridHeight);
	FCell neighborSHCoeffs = _SHCoefficientsGridOld[neighborGridPositionIndex];

	FCellFloat neighborSHCoeffsFloat = FCellToFloat(neighborSHCoeffs);
	
	// FCellFloat coneSHCoeffs = SHCone90DegreeL2(-float3(offset.x, offset.y, offset.z));
	// float4 coneSHCoeffsFloat4 = SHCone90Degree(-float3(offset.x, offset.y, offset.z));
	float4 coneSHCoeffsFloat4 = ConeSHL1[offsetIndex];
	float coneSHCoeffs4[4] = { coneSHCoeffsFloat4.x, coneSHCoeffsFloat4.y, coneSHCoeffsFloat4.z, coneSHCoeffsFloat4.w };
	float3 incommingLuminenceL1 = float3(0, 0, 0);
	for (int i = 0; i < 4; i++)
	{
		incommingLuminenceL1.r += neighborSHCoeffsFloat.sh_r[i] * coneSHCoeffs4[i];
		incommingLuminenceL1.g += neighborSHCoeffsFloat.sh_g[i] * coneSHCoeffs4[i];
		incommingLuminenceL1.b += neighborSHCoeffsFloat.sh_b[i] * coneSHCoeffs4[i];
	}
	
	for (int j = 0; j < 4; j++)
	{
		// coneSHCoeffs only has sh_r
		gatheredSHCoeffs.sh_r[j] += coneSHCoeffs4[j] * incommingLuminenceL1.r;
		gatheredSHCoeffs.sh_g[j] += coneSHCoeffs4[j] * incommingLuminenceL1.g;
		gatheredSHCoeffs.sh_b[j] += coneSHCoeffs4[j] * incommingLuminenceL1.b;
	}
	
}



[numthreads(2, 2, 2)]
void PropagateIrradiance(uint3 id : SV_DispatchThreadID)
{
	float propagation = 0.6f;
	FCellFloat gatheredSHCoeffs = (FCellFloat) 0;
	int pos = id.x + id.y * (_GridWidth) + id.z * (_GridWidth * _GridHeight);
	gatheredSHCoeffs.isVisible = _SHCoefficientsGridOld[pos].isVisible;
	
	// gather irradiance from neighboring cells
	AddContributionFromNeighbor(id, gatheredSHCoeffs, pos, int3(1, 0, 0), 3);
	AddContributionFromNeighbor(id, gatheredSHCoeffs, pos, int3(-1, 0, 0), 0);
	AddContributionFromNeighbor(id, gatheredSHCoeffs, pos, int3(0, 1, 0), 4);
	AddContributionFromNeighbor(id, gatheredSHCoeffs, pos, int3(0, -1, 0), 1);
	AddContributionFromNeighbor(id, gatheredSHCoeffs, pos, int3(0, 0, 1), 5);
	AddContributionFromNeighbor(id, gatheredSHCoeffs, pos, int3(0, 0, -1), 2);

	FCell gatheredSHCoeffsInt = FCellFloatToInt(gatheredSHCoeffs);
	_SHCoefficientsGridNew0[pos].isVisible = gatheredSHCoeffs.isVisible;
	// add gathered irradiance to the current cell
	for (int i = 0; i < 9; i++)
	{
		_SHCoefficientsGridNew0[pos].sh_r[i] = _SHCoefficientsGridOld[pos].sh_r[i] * (1 - propagation) + gatheredSHCoeffsInt.sh_r[i] * propagation;
		_SHCoefficientsGridNew0[pos].sh_g[i] = _SHCoefficientsGridOld[pos].sh_g[i] * (1 - propagation) + gatheredSHCoeffsInt.sh_g[i] * propagation;
		_SHCoefficientsGridNew0[pos].sh_b[i] = _SHCoefficientsGridOld[pos].sh_b[i] * (1 - propagation) + gatheredSHCoeffsInt.sh_b[i] * propagation;
	}

}

[numthreads(2, 2, 2)]
void AddNewLighting(uint3 id : SV_DispatchThreadID)
{
	int pos = id.x + id.y * (_GridWidth) + id.z * (_GridWidth * _GridHeight);
	float updateAlpha = 0.4f;
	for (int i = 0; i < 9; i++)
	{
		_SHCoefficientsGridFinal[pos].sh_r[i] = _SHCoefficientsGridNew0[pos].sh_r[i] * updateAlpha + (1 - updateAlpha) * _SHCoefficientsGridFinal[pos].sh_r[i];
		_SHCoefficientsGridFinal[pos].sh_g[i] = _SHCoefficientsGridNew0[pos].sh_g[i] * updateAlpha + (1 - updateAlpha) * _SHCoefficientsGridFinal[pos].sh_g[i];
		_SHCoefficientsGridFinal[pos].sh_b[i] = _SHCoefficientsGridNew0[pos].sh_b[i] * updateAlpha + (1 - updateAlpha) * _SHCoefficientsGridFinal[pos].sh_b[i];
	}
}

float3 _CameraPositionOffset;
RWStructuredBuffer<FCell> _GridAfterShift;

[numthreads(2, 2, 2)]
void ShiftGrid(uint3 id : SV_DispatchThreadID)
{
	int pos = id.x + id.y * (_GridWidth) + id.z * (_GridWidth * _GridHeight);
	int3 newPosVector = id.xyz + round(_CameraPositionOffset);
	if (newPosVector.x >= _GridWidth - 1 || newPosVector.y >= _GridHeight - 1 || newPosVector.z >= _GridDepth - 1 || newPosVector.x < 1 || newPosVector.y < 1 || newPosVector.z < 1)
	{
		_GridAfterShift[pos] = (FCell) 0;
		return;
	}
	int newPos = newPosVector.x + newPosVector.y * (_GridWidth) + newPosVector.z * (_GridWidth * _GridHeight);
	_GridAfterShift[pos] = _SHCoefficientsGridFinal[newPos];
}