// Each #kernel tells which function to compile; you can have many kernels
#pragma kernel CSMain
#pragma kernel CopyToVolumeTexture
#pragma kernel PropagateIrradiance
#pragma kernel AddNewLighting
#pragma kernel ClearVoxelOcclusionGrid
#pragma kernel ShiftGrid

#define MAX_CASCADES 4
// Create a RenderTexture with enableRandomWrite flag and set it
// with cs.SetTexture

struct FCell
{
	int sh_r[9];
	int sh_g[9];
	int sh_b[9];
	uint count;
	uint avgCount;
	uint isVisible;
};

struct FCellFloat
{
	float sh_r[9];
	float sh_g[9];
	float sh_b[9];
	uint count;
	uint avgCount;
	uint isVisible;
};

RWStructuredBuffer<FCell> _SHCoefficientsGrid0;
RWStructuredBuffer<FCell> _SHCoefficientsGrid1;
RWStructuredBuffer<FCell> _SHCoefficientsGrid2;
RWStructuredBuffer<FCell> _SHCoefficientsGrid3;

StructuredBuffer<FCell> _SHCoefficientsGridOld;

RWStructuredBuffer<FCell> _SHCoefficientsGridNew0;
RWStructuredBuffer<FCell> _SHCoefficientsGridNew1;
RWStructuredBuffer<FCell> _SHCoefficientsGridNew2;
RWStructuredBuffer<FCell> _SHCoefficientsGridNew3;

RWStructuredBuffer<FCell> _SHCoefficientsGridFinal;
RWTexture3D<float4> _SHCoefficientsVolume;
RWStructuredBuffer<float> _VoxelOcclusionGrid;

int _GridWidth;
int _GridHeight;
int _GridDepth;
int _Downsample;
int _Precision;
int _NumCascades;
float _VoxelGridScale;

static const float4 ConeSHL1[6] =
{
	float4(0.282094f, 0.0f, 0.0f, 0.2443012f),
	float4(0.282094f, 0.2443012f, 0.0f, 0.0f),
	float4(0.282094f, 0.0f, 0.2443012f, 0.0f),
	float4(0.282094f, 0.0f, 0.0f, -0.2443012f),
	float4(0.282094f, -0.2443012f, 0.0f, 0.0f),
	float4(0.282094f, 0.0f, -0.2443012f, 0.0f),
};
FCellFloat ScaleFCellFloat(in FCellFloat cell, float factor)
{
	FCellFloat newCell = (FCellFloat) 0;
	newCell.avgCount = cell.avgCount;
	newCell.count = cell.count;
	newCell.isVisible = cell.isVisible;
	for (int i = 0; i < 9; i++)
	{
		newCell.sh_r[i] = cell.sh_r[i] * factor;
		newCell.sh_g[i] = cell.sh_g[i] * factor;
		newCell.sh_b[i] = cell.sh_b[i] * factor;
	}
	return newCell;
}

FCellFloat FCellToFloat(in FCell cell)
{
	FCellFloat fcellFloat = (FCellFloat) 0;
	for (int i = 0; i < 9; i++)
	{
		fcellFloat.sh_r[i] = ((float) cell.sh_r[i]) / _Precision;
		fcellFloat.sh_g[i] = ((float) cell.sh_g[i]) / _Precision;
		fcellFloat.sh_b[i] = ((float) cell.sh_b[i]) / _Precision;
	}
	fcellFloat.count = cell.count;
	fcellFloat.avgCount = cell.avgCount;
	fcellFloat.isVisible = cell.isVisible;
	return fcellFloat;
}

FCell FCellFloatToInt(in FCellFloat cell)
{
	FCell fcell = (FCell) 0;
	for (int i = 0; i < 9; i++)
	{
		fcell.sh_r[i] = floor(cell.sh_r[i] * _Precision);
		fcell.sh_g[i] = floor(cell.sh_g[i] * _Precision);
		fcell.sh_b[i] = floor(cell.sh_b[i] * _Precision);
	}
	fcell.count = cell.count;
	fcell.avgCount = cell.avgCount;
	fcell.isVisible = cell.isVisible;
	return fcell;
}

float4 SHCone90Degree(in float3 dir)
{
	float4 c = float4(
        1.77245f,
        1.53499f * dir.y,
        1.53499f * dir.z,
        1.53499f * dir.x
    );

	return c * (1.0 / (2.0 * 3.14159265));
}

void SHEvalBasis9(float3 d, out float b[9])
{
	float x = d.x;
	float y = d.y;
	float z = d.z;

	b[0] = 0.282095;

	b[1] = 0.488603 * y;
	b[2] = 0.488603 * z;
	b[3] = 0.488603 * x;

	b[4] = 1.092548 * x * y;
	b[5] = 1.092548 * y * z;
	b[6] = 0.315392 * (3.0 * z * z - 1.0);
	b[7] = 1.092548 * x * z;
	b[8] = 0.546274 * (x * x - y * y);
}

FCellFloat SHCone90DegreeL2(in float3 dir)
{
	FCellFloat data = (FCellFloat) 0;

	float b[9];
	SHEvalBasis9(dir, b);

	const float k0 = 1.00;
	const float k1 = 0.75; 
	const float k2 = 0.25;

	data.sh_r[0] = k0 * b[0];

	data.sh_r[1] = k1 * b[1];
	data.sh_r[2] = k1 * b[2];
	data.sh_r[3] = k1 * b[3];

	data.sh_r[4] = k2 * b[4];
	data.sh_r[5] = k2 * b[5];
	data.sh_r[6] = k2 * b[6];
	data.sh_r[7] = k2 * b[7];
	data.sh_r[8] = k2 * b[8];

	return data;
}



[numthreads(2, 2, 2)]
void CSMain(uint3 id : SV_DispatchThreadID)
{
    int idx = id.x + id.y * (_GridWidth) + id.z * (_GridWidth * _GridHeight);
	FCell emptyCell = (FCell) 0;

	FCell initCell = (FCell) 0;
	// initCell.count = 1;
	// initCell.avgCount = 1;

	_SHCoefficientsGrid0[idx] = emptyCell;
	_SHCoefficientsGridNew0[idx] = initCell;

	/*_SHCoefficientsGrid1[idx] = emptyCell;
	_SHCoefficientsGridNew1[idx] = initCell;

	_SHCoefficientsGrid2[idx] = emptyCell;
	_SHCoefficientsGridNew2[idx] = initCell;

	_SHCoefficientsGrid3[idx] = emptyCell;
	_SHCoefficientsGridNew3[idx] = initCell;*/

}

[numthreads(2, 2, 2)]
void ClearVoxelOcclusionGrid(uint3 id : SV_DispatchThreadID)
{
	int pos = round(id.x + id.y * (_GridWidth / _VoxelGridScale) + id.z * (_GridWidth / _VoxelGridScale * _GridHeight / _VoxelGridScale));
	_VoxelOcclusionGrid[pos] = 0;
}


